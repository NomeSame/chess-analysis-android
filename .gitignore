app/src/main/res/raw/nnue_big.nnue

# llama.cpp source tree — cloned at CMake-configure time (see cpp/CMakeLists.txt), not our source
app/src/main/cpp/llama.cpp/

# Python bytecode cache (dev tools)
__pycache__/

# Documentation / status files — removed from history
SVG_IMPLEMENTATION.md
status.md
.claude/
ANALYSIS_REVIEW_TODO.md
TODO.md
UMFORMULIERUNG.md

# Local test/example images — not part of the app
chess1.jpg
chess2.jpg

