<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Main content (scrollable so setup-mode controls stay reachable) -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:background="#FF5A5A5A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp">

        <!-- Top bar: status (left) + settings gear (right) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:minHeight="48dp">

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/initializing"
                android:textSize="14sp"
                android:textColor="#2196F3" />

            <ImageButton
                android:id="@+id/btnSettings"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_settings"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:scaleType="centerInside"
                android:contentDescription="Settings" />
        </LinearLayout>

        <!-- Analysis progress: bar + x/y text side by side (visible only while analyzing). -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:visibility="gone"
            android:id="@+id/llAnalysisProgress">

            <ProgressBar
                android:id="@+id/pbAnalysis"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="100"
                android:progress="0" />

            <TextView
                android:id="@+id/tvAnalysisProgress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:textSize="13sp"
                android:textColor="#2196F3"
                android:minWidth="60dp"
                android:gravity="center" />
        </LinearLayout>

        <!-- Eval curve (analysis view only) — sits above the board, Chess.com style. -->
        <com.example.chessanalysis.ui.EvalChartView
            android:id="@+id/evalChart"
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:layout_marginTop="8dp"
            android:visibility="gone" />

        <!-- Board + eval bar, pushed down below the top bar. Height hugs the (square) board. -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/tvPuzzleSide"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:textSize="12sp"
                        android:textColor="#FFAAAAAA"
                        android:visibility="gone" />
                    <TextView
                        android:id="@+id/tvPuzzleTheme"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:textSize="12sp"
                        android:textColor="#FF888888"
                        android:visibility="gone" />
                    <TextView
                        android:id="@+id/tvPuzzleRating"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#FFDDDDDD"
                        android:visibility="gone" />
                </LinearLayout>
                <Button
                    android:id="@+id/btnPuzzleSkip"
                    style="?android:attr/borderlessButtonStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="→"
                    android:textSize="20sp"
                    android:textColor="#FFAAAAAA"
                    android:gravity="center"
                    android:padding="8dp"
                    android:visibility="gone" />
            </LinearLayout>

            <com.example.chessanalysis.ui.ChessBoardView
                android:id="@+id/chessBoard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- AI Coach auto-comment panel (analysis view only) — between board and controls -->
        <LinearLayout
            android:id="@+id/coachPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="8dp"
            android:padding="10dp"
            android:background="#FF333333"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/coach_title"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#FF9E9E9E"
                android:textAllCaps="true"
                android:letterSpacing="0.05" />

            <TextView
                android:id="@+id/tvCoachBody"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textSize="14sp"
                android:textColor="#FFEEEEEE"
                android:lineSpacingMultiplier="1.1" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/moveListRecycler"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="4dp"
            android:visibility="gone"
            android:clipToPadding="false"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:requiresFadingEdge="horizontal"
            android:fadingEdgeLength="16dp" />

        <!-- Position navigation: prev / next / reset-to-live / undo / hint — flush under the board -->
        <LinearLayout
            android:id="@+id/navButtonsRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btnPrev"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="◀"
                android:textColor="#000000"
                android:textSize="26sp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Previous move" />

            <TextView
                android:id="@+id/btnNext"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="▶"
                android:textColor="#000000"
                android:textSize="26sp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Next move" />

            <TextView
                android:id="@+id/btnResetView"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="⟳"
                android:textColor="#000000"
                android:textStyle="bold"
                android:textSize="32sp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Jump to current position" />

            <TextView
                android:id="@+id/btnReviewAnalyze"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="center_vertical"
                android:gravity="center"
                android:text="▶"
                android:textColor="#FFFFFFFF"
                android:textStyle="bold"
                android:textSize="20sp"
                android:background="@drawable/bg_review_analyze"
                android:visibility="gone"
                android:contentDescription="@string/analyze_game" />

            <TextView
                android:id="@+id/btnUndo"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="↩"
                android:textColor="#000000"
                android:textStyle="bold"
                android:textSize="32sp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Undo last move" />

            <TextView
                android:id="@+id/btnHint"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="💡"
                android:textSize="24sp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Best-move hint" />
        </LinearLayout>

        <!-- Top-3 engine moves (live), best move always on top -->
        <LinearLayout
            android:id="@+id/moveBarsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.example.chessanalysis.ui.MoveEvalBar
                android:id="@+id/mb1"
                android:layout_width="match_parent"
                android:layout_height="34dp"
                android:layout_marginTop="8dp" />

            <com.example.chessanalysis.ui.MoveEvalBar
                android:id="@+id/mb2"
                android:layout_width="match_parent"
                android:layout_height="34dp"
                android:layout_marginTop="4dp" />

            <com.example.chessanalysis.ui.MoveEvalBar
                android:id="@+id/mb3"
                android:layout_width="match_parent"
                android:layout_height="34dp"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Analysis counts panel (per-class tally + accuracy per side); populated in code, GONE by default. -->
        <LinearLayout
            android:id="@+id/countsPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="10dp"
            android:padding="10dp"
            android:background="#FF2E2E2E"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/color_white"
                    android:textColor="#FFFFFFFF"
                    android:textStyle="bold"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/color_black"
                    android:textColor="#FFFFFFFF"
                    android:textStyle="bold"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="2dp">

                <TextView
                    android:id="@+id/tvAccWhite"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:textColor="#FF81B64C"
                    android:textStyle="bold"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/tvAccBlack"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:textColor="#FF81B64C"
                    android:textStyle="bold"
                    android:textSize="16sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/countsRows"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="6dp" />
        </LinearLayout>

        <Button
            android:id="@+id/btnExportPgn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/export_pgn"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/homeActionsRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <Button
                android:id="@+id/btnNewGame"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="@string/new_game"
                android:ellipsize="end"
                android:maxLines="1"
                android:singleLine="true" />

            <Button
                android:id="@+id/btnSetupMode"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:text="@string/setup_board"
                android:ellipsize="end"
                android:maxLines="1"
                android:singleLine="true" />

        </LinearLayout>

        <!-- Game History header + Learn Theory button (same line) -->
        <LinearLayout
            android:id="@+id/historyHeaderRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="6dp"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvGameHistoryHeader"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/game_history"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFFFF"
                    android:visibility="gone" />

                <ImageButton
                    android:id="@+id/btnPuzzles"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_puzzle"
                    android:scaleType="fitCenter"
                    android:padding="6dp"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/puzzles" />

            </LinearLayout>

            <Button
                android:id="@+id/btnLearnTheory"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="@string/learn_theory"
                android:ellipsize="end"
                android:maxLines="1"
                android:singleLine="true" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/historyImportRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">

            <Button
                android:id="@+id/btnExportHistory"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="@string/export_history" />

            <Button
                android:id="@+id/btnImportHistory"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="@string/import_history" />
        </LinearLayout>

        <Button
            android:id="@+id/btnExportPgnHistory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/export_pgn" />

        <LinearLayout
            android:id="@+id/lvGameHistory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:visibility="gone"
            android:background="#FF3A3A3A"
            android:orientation="vertical" />

    </LinearLayout>
    </ScrollView>

    <!-- Settings sidebar (end drawer). Width set dynamically to 2/3 of screen. -->
    <ScrollView
        android:id="@+id/settingsDrawer"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:background="#FFFFFFFF"
        android:elevation="16dp"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_title"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#212121" />

            <!-- Gameplay header + EN/DE language toggle -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/gameplay"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#757575"
                    android:textAllCaps="true"
                    android:letterSpacing="0.05" />

                <LinearLayout
                    android:id="@+id/langToggle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/langEn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:minWidth="40dp"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp"
                        android:gravity="center"
                        android:text="EN"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/langDe"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:minWidth="40dp"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp"
                        android:gravity="center"
                        android:text="DE"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- Display options (collapsible) — all on/off toggles -->
            <TextView
                android:id="@+id/tvTogglesHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:minHeight="40dp"
                android:gravity="center_vertical"
                android:text="@string/display_options"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#757575"
                android:textAllCaps="true"
                android:letterSpacing="0.05"
                android:background="?attr/selectableItemBackground" />

            <LinearLayout
                android:id="@+id/llToggles"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/show_legal"
                    android:textSize="15sp"
                    android:textColor="#212121" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/swLegalMoves"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/show_move_bars"
                    android:textSize="15sp"
                    android:textColor="#212121" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/swMoveBars"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/show_eval_bar"
                    android:textSize="15sp"
                    android:textColor="#212121" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/swEvalBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/live_eval"
                    android:textSize="15sp"
                    android:textColor="#212121" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/swLiveEval"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="false" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/show_analysis_arrows"
                    android:textSize="15sp"
                    android:textColor="#212121" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/swAnalysisArrows"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/piece_sounds"
                    android:textSize="15sp"
                    android:textColor="#212121" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/swPieceSounds"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true" />
            </LinearLayout>

            </LinearLayout>
            <!-- /llToggles -->

            <!-- Sound theme (collapsible) -->
            <TextView
                android:id="@+id/tvSoundThemeHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:minHeight="40dp"
                android:gravity="center_vertical"
                android:text="@string/sound_theme"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#757575"
                android:textAllCaps="true"
                android:letterSpacing="0.05"
                android:background="?attr/selectableItemBackground" />

            <RadioGroup
                android:id="@+id/rgSoundTheme"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="vertical"
                android:visibility="gone" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="16dp"
                android:background="#E0E0E0" />

            <!-- Board theme (collapsible) -->
            <TextView
                android:id="@+id/tvBoardThemeHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:minHeight="40dp"
                android:gravity="center_vertical"
                android:text="@string/board_theme"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#757575"
                android:textAllCaps="true"
                android:letterSpacing="0.05"
                android:background="?attr/selectableItemBackground" />

            <RadioGroup
                android:id="@+id/rgBoardTheme"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="vertical"
                android:visibility="gone" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="16dp"
                android:background="#E0E0E0" />

            <!-- Pieces (collapsible) -->
            <TextView
                android:id="@+id/tvPiecesHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:minHeight="40dp"
                android:gravity="center_vertical"
                android:text="@string/pieces"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#757575"
                android:textAllCaps="true"
                android:letterSpacing="0.05"
                android:background="?attr/selectableItemBackground" />

            <RadioGroup
                android:id="@+id/rgPieceStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="vertical"
                android:visibility="gone" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="16dp"
                android:background="#E0E0E0" />

            <!-- Engine strength (ELO) -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/opponent_strength"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#757575"
                android:textAllCaps="true"
                android:letterSpacing="0.05" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/strength_elo"
                    android:textSize="15sp"
                    android:textColor="#212121" />

                <TextView
                    android:id="@+id/tvEloValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/elo_maximum"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#212121" />
            </LinearLayout>

            <SeekBar
                android:id="@+id/sbElo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:minHeight="48dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
                android:thumb="@drawable/seekbar_thumb"
                android:max="40" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="16dp"
                android:background="#E0E0E0" />

            <TextView
                android:id="@+id/tvAnalysisDepthHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Analysis Depth"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#757575"
                android:textAllCaps="true"
                android:letterSpacing="0.05" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/analysis_depth"
                    android:textSize="15sp"
                    android:textColor="#212121" />
                <TextView
                    android:id="@+id/tvDepthValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#212121" />
            </LinearLayout>
            <SeekBar
                android:id="@+id/sbAnalysisDepth"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="29"
                android:progress="15"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
                android:thumb="@drawable/seekbar_thumb" />

            <!-- AI Coach -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="16dp"
                android:background="#E0E0E0" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="AI Coach"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#757575"
                android:textAllCaps="true"
                android:letterSpacing="0.05" />

            <TextView
                android:id="@+id/tvAiCoachSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textSize="12sp"
                android:textColor="#9E9E9E"
                android:text="Wähle wie der Coach deine Züge erklärt" />

            <LinearLayout
                android:id="@+id/llAiCoachCards"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="vertical" />

        </LinearLayout>
    </ScrollView>

</androidx.drawerlayout.widget.DrawerLayout>
